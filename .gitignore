__pycache__/
*.pyc

# Fonts (19MB Noto CJK — fetched by tools/fetch_assets.sh)
assets/fonts/*.ttc
assets/fonts/*.ttf
!assets/fonts/.gitkeep

# BGM (~17MB MP3 — fetched by tools/fetch_music.sh, CC-BY)
assets/audio/*.mp3
assets/audio/*.ogg
!assets/audio/.gitkeep
!assets/audio/CREDITS.txt
# SFX is tiny (~140KB total, procedurally generated) — bundled in repo.
# Regenerate with tools/fetch_sfx.sh if missing.

# PCE-CD sprites — CC-BY-SA 4.0 from wizardry.wiki.gg, OK to bundle in repo.
# (tools/fetch_pcecd_sprites.sh still available for re-fetching upstream)

# Derived themes (mono/outline/sepia) — regenerated locally by
# tools/generate_themes.py from the bundled PCE-CD master sprites.
# Same CC-BY-SA licence, but kept out of the repo to keep the tree light.
assets/themes/mono/
assets/themes/outline/
assets/themes/sepia/

# Local-only theme dirs populated by tools/extract_*.sh from ROMs the
# user owns (PC-98, WonderSwan Color, Macintosh, PCE-CD audio).
# NEVER committed — copyrighted material.
assets/themes/pc98/
assets/themes/wsc/
assets/themes/mac/
assets/themes/pcecd_local/


# Reference materials (not committed — see docs/REFERENCES.md)
release/
*.iso
Ultimate*Archives*.pdf

